<Window x:Class="FreewriteWindows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Freewrite"
        Width="1100"
        Height="600"
        MinWidth="1100"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Background="White"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="PlainButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#111111" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DialogButton" TargetType="Button" BasedOn="{StaticResource PlainButton}">
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Background" Value="#EEEEEE" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0.65" />
        </Style>

        <Style TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#777777" CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="SidebarColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <Grid x:Name="MainSurface"
              Grid.Column="0"
              MouseLeftButtonDown="MainSurface_MouseLeftButtonDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="68" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <MediaElement x:Name="VideoPlayer"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop"
                              Stretch="UniformToFill"
                              Visibility="Collapsed"
                              MediaEnded="VideoPlayer_MediaEnded"
                              MediaFailed="VideoPlayer_MediaFailed" />

                <Grid x:Name="EditorShell"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Width="650"
                      MaxWidth="650"
                      Margin="0,40,0,0">
                    <TextBox x:Name="EditorTextBox"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="Lato"
                             FontSize="18"
                             Foreground="#333333"
                             HorizontalScrollBarVisibility="Disabled"
                             IsUndoEnabled="False"
                             Padding="5,0,28,68"
                             SpellCheck.IsEnabled="False"
                             TextChanged="EditorTextBox_TextChanged"
                             TextWrapping="Wrap"
                             VerticalAlignment="Stretch"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type ScrollViewer}">
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock x:Name="PlaceholderText"
                               Margin="5,0,28,0"
                               VerticalAlignment="Top"
                               FontFamily="Lato"
                               FontSize="18"
                               Foreground="#BBBBBB"
                               IsHitTestVisible="False"
                               Text="Begin writing"
                               Visibility="Collapsed" />
                </Grid>
            </Grid>

            <Grid x:Name="BottomNav"
                  Grid.Row="1"
                  Height="68"
                  Background="Transparent"
                  MouseEnter="BottomNav_MouseEnter"
                  MouseLeave="BottomNav_MouseLeave">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  Padding="18,0,8,0">
                        <StackPanel x:Name="BottomNavItems"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="CopyTranscriptButton" Content="Copy Transcript" Style="{StaticResource PlainButton}" Click="CopyTranscript_Click" Visibility="Collapsed" />
                            <TextBlock x:Name="VideoControlsSeparatorA" Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" Visibility="Collapsed" />
                            <Button x:Name="VideoPlayButton" Content="Pause" Style="{StaticResource PlainButton}" Click="VideoPlay_Click" Visibility="Collapsed" />
                            <TextBlock x:Name="VideoControlsSeparatorB" Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" Visibility="Collapsed" />
                            <Button x:Name="VideoMuteButton" Content="Unmute" Style="{StaticResource PlainButton}" Click="VideoMute_Click" Visibility="Collapsed" />
                            <TextBlock x:Name="VideoControlsSeparatorC" Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" Visibility="Collapsed" />
                            <Button x:Name="FontSizeButton" Content="18px" Style="{StaticResource PlainButton}" Click="FontSize_Click" />
                            <TextBlock x:Name="FontSep1" Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" />
                            <Button x:Name="LatoButton" Content="Lato" Style="{StaticResource PlainButton}" Click="Lato_Click" />
                            <TextBlock x:Name="FontSep2" Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" />
                            <Button x:Name="ArialButton" Content="Arial" Style="{StaticResource PlainButton}" Click="Arial_Click" />
                            <TextBlock x:Name="FontSep3" Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" />
                            <Button x:Name="SystemFontButton" Content="System" Style="{StaticResource PlainButton}" Click="SystemFont_Click" />
                            <TextBlock x:Name="FontSep4" Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" />
                            <Button x:Name="SerifButton" Content="Serif" Style="{StaticResource PlainButton}" Click="Serif_Click" />
                            <TextBlock x:Name="FontSep5" Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" />
                            <Button x:Name="RandomFontButton" Content="Random" Style="{StaticResource PlainButton}" Click="RandomFont_Click" />
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer Grid.Column="1"
                                  HorizontalAlignment="Right"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  Padding="8,0,18,0">
                        <StackPanel x:Name="BottomActionItems"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="TimerButton" Content="15:00" Style="{StaticResource PlainButton}" Click="Timer_Click" MouseDoubleClick="Timer_DoubleClick" MouseWheel="Timer_MouseWheel" />
                            <TextBlock Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" />
                            <Button x:Name="VideoButton" Content="Video" Style="{StaticResource PlainButton}" Click="Video_Click" />
                            <TextBlock Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" />
                            <Button x:Name="ChatButton" Content="Chat" Style="{StaticResource PlainButton}" Click="Chat_Click" />
                            <TextBlock x:Name="BackspaceSeparator" Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" />
                            <Button x:Name="BackspaceButton" Content="Backspace is On" Style="{StaticResource PlainButton}" Click="Backspace_Click" />
                            <TextBlock Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" />
                            <Button x:Name="FullscreenButton" Content="Fullscreen" Style="{StaticResource PlainButton}" Click="Fullscreen_Click" />
                            <TextBlock Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" />
                            <Button Content="New Entry" Style="{StaticResource PlainButton}" Click="NewEntry_Click" />
                            <TextBlock Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" />
                            <Button x:Name="ThemeButton" Content="Dark Mode" Style="{StaticResource PlainButton}" Click="Theme_Click" />
                            <TextBlock Text=" &#8226; " Foreground="#999999" VerticalAlignment="Center" />
                            <Button x:Name="HistoryButton" Style="{StaticResource PlainButton}" Click="History_Click" ToolTip="History">
                                <Viewbox Width="13" Height="13">
                                    <Canvas Width="16" Height="16">
                                        <Ellipse Width="13"
                                                 Height="13"
                                                 Canvas.Left="1.5"
                                                 Canvas.Top="1.5"
                                                 Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                 StrokeThickness="1.4" />
                                        <Path Data="M8,4.5 L8,8 L10.8,9.8"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <Border x:Name="Sidebar"
                Grid.Column="1"
                BorderBrush="#EEEEEE"
                BorderThickness="1,0,0,0"
                Background="White"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="14,12,10,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="SidebarTitleText"
                               Text="Entries"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#222222" />
                    <Button x:Name="SidebarFolderButton"
                            Grid.Column="1"
                            Content="Folder"
                            Style="{StaticResource PlainButton}"
                            FontSize="12"
                            Margin="0,0,12,0"
                            Click="OpenFolder_Click" />
                    <Button x:Name="CloseSidebarButton"
                            Grid.Column="2"
                            Content="x"
                            Style="{StaticResource PlainButton}"
                            FontSize="14"
                            Padding="4,0"
                            Click="CloseSidebar_Click" />
                    <TextBlock x:Name="FolderPathText"
                               Grid.Row="1"
                               Grid.ColumnSpan="3"
                               Margin="0,4,0,0"
                               FontSize="10"
                               Foreground="#999999"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel x:Name="HistoryItems" />
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid x:Name="DeleteOverlay"
              Grid.ColumnSpan="2"
              Background="#66000000"
              Visibility="Collapsed">
            <Border x:Name="DeleteDialog"
                    Width="320"
                    Padding="22,20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock x:Name="DeleteDialogTitle"
                               Text="Delete this entry?"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#222222" />
                    <TextBlock x:Name="DeleteDialogBody"
                               Margin="0,8,0,20"
                               Text="This removes the local entry file and any linked video assets."
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#777777" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CancelDeleteButton"
                                Content="Cancel"
                                Style="{StaticResource DialogButton}"
                                Margin="0,0,18,0"
                                Click="CancelDelete_Click" />
                        <Button x:Name="ConfirmDeleteButton"
                                Content="Delete"
                                Style="{StaticResource DialogButton}"
                                FontWeight="SemiBold"
                                Click="ConfirmDelete_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="RecordOverlay"
              Grid.ColumnSpan="2"
              Background="#66000000"
              Visibility="Collapsed">
            <Border x:Name="RecordDialog"
                    Width="300"
                    Padding="22,20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Ellipse x:Name="RecordingPulseDot"
                                 Width="8"
                                 Height="8"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 Fill="#E84B4B" />
                        <TextBlock x:Name="RecordingStatusText"
                                   Text="Recording"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#E84B4B"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                        <TextBlock x:Name="RecordElapsedText"
                                   Text="0:00"
                                   FontSize="24"
                                   Foreground="#777777"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button x:Name="StopRecordingButton"
                            Content="Stop Recording"
                            HorizontalAlignment="Right"
                            Style="{StaticResource DialogButton}"
                            Click="StopRecording_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

